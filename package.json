{
  "name": "tenure",
  "version": "1.0.20",
  "description": "",
  "license": "MIT",
  "author": "",
  "type": "module",
  "main": "dist/index.js",
  "bin": {
    "tenure": "dist/index.js"
  },
  "scripts": {
    "build": "tsgo --project tsconfig.build.json",
    "start": "node dist/index.js",
    "dev": "tsx watch src/index.ts",
    "test": "NODE_OPTIONS='--import tsx' ava",
    "test:coverage": "NODE_OPTIONS='--import tsx' c8 ava",
    "test:eval": "NODE_OPTIONS='--import tsx' ava 'src/eval/retrieval.eval.test.ts' 'src/eval/session-retrieval.eval.test.ts' --timeout=5m",
    "test:watch": "ava --watch --ignore='**/*.eval.test.ts'",
    "verify": "npm audit --audit-level=high"
  },
  "dependencies": {
    "@anthropic-ai/sdk": "0.95.2",
    "@fastify/schedule": "6.0.0",
    "@fastify/static": "9.1.3",
    "@fastify/websocket": "^11.2.0",
    "fastify": "5.8.5",
    "mongodb": "7.2.0",
    "mongodb-client-encryption": "7.0.0",
    "smol-toml": "1.6.1",
    "toad-scheduler": "4.0.1",
    "ua-parser-js": "^2.0.9"
  },
  "devDependencies": {
    "@changesets/cli": "^2.31.0",
    "@types/node": "25.6.0",
    "@types/sinon": "21.0.1",
    "@types/ws": "^8.18.1",
    "@typescript/native-preview": "7.0.0-dev.20260506.1",
    "ava": "8.0.0",
    "c8": "11.0.0",
    "mongodb-memory-server": "11.0.1",
    "sinon": "21.1.2",
    "tsx": "4.21.0",
    "typescript": "6.0.3"
  },
  "ava": {
    "timeout": "120s",
    "extensions": [
      "ts"
    ],
    "nodeArguments": [
      "--import=tsx"
    ],
    "files": [
      "src/**/*.test.ts",
      "!src/**/*.eval.test.ts"
    ],
    "workerThreads": false
  }
}
