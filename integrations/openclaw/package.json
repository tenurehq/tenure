{
  "name": "@tenureai/openclaw-plugin",
  "version": "1.0.17",
  "description": "Persistent local memory for OpenClaw. Tenure stores beliefs as actionable instructions, not just facts, so the model acts on context immediately without inference. Zero-config per-agent isolation, fully local, nothing leaves localhost.",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/tenurehq/tenure.git",
    "directory": "integrations/openclaw"
  },
  "keywords": [
    "openclaw",
    "openclaw-plugin",
    "ai-agent",
    "persistent-memory",
    "long-term-memory",
    "context-retention",
    "user-preferences",
    "communication-style",
    "workflow-tool",
    "research-assistant",
    "writing-assistant",
    "local-ai",
    "cognitive-proxy",
    "memory",
    "fast-memory",
    "accurate-memory"
  ],
  "type": "module",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "default": "./dist/index.js"
    }
  },
  "types": "./dist/index.d.ts",
  "files": [
    "dist",
    "skills",
    "openclaw.plugin.json",
    "README.md"
  ],
  "openclaw": {
    "extensions": [
      "./src/index.ts"
    ],
    "providers": [
      "tenure"
    ],
    "compat": {
      "pluginApi": ">=2026.6.8",
      "minGatewayVersion": "2026.6.8"
    },
    "build": {
      "openclawVersion": "2026.6.8",
      "pluginSdkVersion": "2026.6.8"
    }
  },
  "scripts": {
    "build": "tsgo",
    "dev": "tsc --watch",
    "prepublishOnly": "npm run build",
    "test": "ava",
    "test:watch": "ava --watch"
  },
  "devDependencies": {
    "@types/node": "25.6.0",
    "@typescript/native-preview": "7.0.0-dev.20260518.1",
    "ava": "8.0.1",
    "openclaw": "^2026.7.1",
    "tsx": "4.22.4",
    "typescript": "6.0.3"
  },
  "overrides": {
    "openclaw": {
      "hono": "4.12.21"
    }
  },
  "ava": {
    "files": [
      "src/**/*.test.ts"
    ],
    "extensions": [
      "ts"
    ],
    "nodeArguments": [
      "--import=tsx/esm"
    ],
    "timeout": "30s",
    "workerThreads": false
  }
}
